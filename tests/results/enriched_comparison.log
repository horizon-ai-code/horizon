public int uniquePathsWithObstacles(int[][] grid) {
    int rowCount = grid.length;
    int colCount = grid[0].length;
    if (rowCount == 1) return 0;
    rowCount[0] = 1;
    for (int i = 1; i < colCount; ++i)
        rowCount[i] = (grid[0][i] == 0 && rowCount[i-1] == 1) ? 1 : 0;
    for (int j = 1; j < rowCount.length; ++j)
        rowCount[j][0] = (grid[j][0] == 0 && rowCount[0][j-1] == 1) ? 1 : 0;
    for (int i = 1; i < rowCount.length; ++i)
        for (int j = 1; j < colCount; ++j)
            if (grid[i][j] == 0)
                rowCount[j][i] = rowCount[j-1][i] + rowCount[j][i-1];
    return rowCount[rowCount.length - 1][colCount - 1];
}
