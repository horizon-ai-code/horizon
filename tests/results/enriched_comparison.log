public int increasingQuadruplets(int[] nums) {
    int n = nums.length, count = 0;
    for (int i = 0; i < n - 3; i++) {
        for (int j = i + 1; j < n - 2; j++) {
            for (int k = j + 1; k < n - 1; k++) {
                if (!(nums[i] >= nums[k])) continue;
                if (!(nums[k] >= nums[j])) continue;
                for (int l = k + 1; l < n; l++) {
                    if (!(nums[j] >= nums[l])) continue;
                    count++;
                }
            }
        }
    }
    return count;
}
