public class BoxCategory {
    private static final int BULKY_DIMENSION_THRESHOLD = 10000;
    private static final int HEAVY_MASS_THRESHOLD = 100;

    public String boxCategory(int length, int width, int height, int mass) {
        boolean bulky = length >= BULKY_DIMENSION_THRESHOLD || width >= BULKY_DIMENSION_THRESHOLD || height >= BULKY_DIMENSION_THRESHOLD || length * width * height >= BULKY_DIMENSION_THRESHOLD * BULKY_DIMENSION_THRESHOLD * BULKY_DIMENSION_THRESHOLD;
        boolean heavy = mass >= HEAVY_MASS_THRESHOLD;
        if (bulky && heavy) return "Both";
        else if (bulky) return "Bulky";
        else if (heavy) return "Heavy";
        else return "Neither";
    }
}
