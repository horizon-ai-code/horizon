public int increasingQuadruplets(int[] nums) {
    if(nums == null || nums.length < 4)
        throw new IllegalArgumentException("Array must have at least four elements");

    int n = nums.length, count = 0;
    for (int i = 0; i < n - 3; i++) {
        if (nums[i] >= nums[i + 1])
            continue;

        for (int j = i + 1; j < n - 2; j++) {
            if (nums[j] <= nums[j + 1])
                continue;

            for (int k = j + 1; k < n - 1; k++) {
                if (nums[k] >= nums[i]) // Changed to check against i instead of k
                    continue;

                for (int l = k + 1; l < n; l++) {
                    count++;
                }
            }
        }
    }

    return count;
}
